WATTTIME_USERNAME=
WATTTIME_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
ANTHROPIC_API_KEY=
AI_SUMMARY_ENABLED=true
AI_SUMMARY_MODEL=claude-haiku-4-5-20251001
AI_SUMMARY_RATE_LIMIT=10

# Backend base URL used by the Streamlit app to call the FastAPI backend.
# Local development (FastAPI running on same machine):
#   UTIL_API_BASE_URL=http://127.0.0.1:8000
# Deployed Streamlit (Render, Streamlit Cloud, etc.) — set to your backend's public URL:
#   UTIL_API_BASE_URL=https://your-backend.onrender.com
# Omit or leave blank to use the local default (http://127.0.0.1:8000).
UTIL_API_BASE_URL=http://127.0.0.1:8000
