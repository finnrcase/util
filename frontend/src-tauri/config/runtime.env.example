# Desktop runtime configuration for the bundled Python backend.
# Copy this file to your platform app config directory as runtime.env.
#
# Windows: %APPDATA%\com.util.desktop\runtime.env
# macOS:   ~/Library/Application Support/com.util.desktop/runtime.env
# Linux:   ~/.config/com.util.desktop/runtime.env

WATTTIME_USERNAME=your_watttime_username
WATTTIME_PASSWORD=your_watttime_password

# Optional overrides
# UTIL_PYTHON_BIN=python
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET_NAME=
